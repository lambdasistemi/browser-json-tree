#!/usr/bin/env bash
# Validate that `spago.yaml`'s `publish.version`, the candidate
# tag (if provided), and `CHANGELOG.md` all agree. Run on every
# CI build, every release-planner run, and as the tag-push
# pre-flight in `release.yml`.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

version="$(scripts/release/get-spago-version)"

changelog_has_release() {
  local release_version="$1"
  local line

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "## [$release_version]"* ]] \
      || [[ "$line" == "## $release_version" ]] \
      || [[ "$line" == "## $release_version "* ]]; then
      return 0
    fi
  done <CHANGELOG.md

  return 1
}

# SemVer surface (X.Y.Z, plus optional pre-release/build).
case "$version" in
  *[!0-9A-Za-z.+-]* | .* | *..* | *.)
    echo "invalid SemVer version: $version" >&2
    exit 1
    ;;
esac

if [[ -e release-please-config.json ]]; then
  echo "release-please-config.json must not exist; spago.yaml owns releases" >&2
  exit 1
fi

if [[ -e .release-please-manifest.json ]]; then
  echo ".release-please-manifest.json must not exist; spago.yaml owns releases" >&2
  exit 1
fi

tag="${1:-}"
if [[ -z "$tag" && "${GITHUB_REF_TYPE:-}" == "tag" ]]; then
  tag="${GITHUB_REF_NAME:-}"
fi

branch_name="${GITHUB_HEAD_REF:-${GITHUB_REF_NAME:-}}"
if [[ -z "$tag" && "$branch_name" == "${RELEASE_BRANCH:-release/spago-release}" ]]; then
  tag="v$version"
fi

if [[ -n "$tag" ]]; then
  tag_version="${tag#refs/tags/}"
  tag_version="${tag_version#v}"

  if [[ "$tag_version" != "$version" ]]; then
    echo "tag version $tag_version does not match spago.yaml version $version" >&2
    exit 1
  fi

  if ! changelog_has_release "$version"; then
    echo "CHANGELOG.md has no release section for $version" >&2
    exit 1
  fi
fi

echo "release version contract ok: spago.yaml $version"
